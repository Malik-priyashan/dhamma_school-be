generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id String @id @default(uuid())
  fullNameWithSurname    String
  nameWithInitials       String?
  dob                    DateTime?
  address                String?
  phone1                 String?
  phone2                 String?
  school                 String?
  earlierSchool          Boolean          @default(false)
  earlierSchoolReason    String?
  reasonForLeave         String?
  fatherFullName         String?
  fatherJob              String?
  fatherJobAddress       String?
  motherFullName         String?
  motherJob              String?
  motherJobAddress       String?
  guardianFullName       String?
  guardianJob            String?
  guardianJobAddress     String?
  emergencyPersonName    String?
  emergencyPersonAddress String?
  emergencyNumber        String?
  disabilities           Boolean          @default(false)
  disabilityReason       String?
  medicated              Boolean          @default(false)
  medicine               String?
  registrationPayment    Float?
  registrationDate       DateTime?
  indexNo                String?
  libraryNo              String?
  house                  String?
  grade                  String?
  studentActiveMonitor   StudentMonitor   @default(NOT_GIVEN)
  agreeToTerms           Boolean          @default(false)
  createdAt              DateTime         @default(now())
  studentImage           String?
  userId                 String?
  user                   User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  siblings StudentSibling[]
  payments RegistrationPayment[]
  marks    Marks[]
  contactUs ContactUs[]

  @@index([userId])
}

model AnnouncingForm {
  id String @id @default(uuid())
  fullNameWithSurname String
  birthday            DateTime?
  address             String?
  phoneLand           String?
  phoneMobile         String?
  school              String?
  guardianName        String?
  guardianAddress     String?
  studentAgreement    Boolean         @default(false)
  marks               Float?
  status              SelectionStatus @default(PENDING)
  createdAt           DateTime        @default(now())
  special Special?
}

model News {
  id           String   @id @default(uuid())
  image        String?
  topic        String
  topicSi      String?
  description  String
  descriptionSi String?
  happenedDate DateTime
  createdAt    DateTime @default(now())

  @@index([happenedDate])
}

model Event {
  id           String   @id @default(uuid())
  image        String?
  images       String?
  topic        String
  topicSi      String?
  description  String
  descriptionSi String?
  happenedDate DateTime
  createdAt    DateTime @default(now())

  @@index([happenedDate])
}

model ContactUs {
  id         String          @id @default(uuid())
  userId     String?
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  studentId  String?
  student    Student?        @relation(fields: [studentId], references: [id], onDelete: SetNull)
  name       String
  message    String
  senderName String
  status     ContactUsStatus @default(NOT_READ)
  createdAt  DateTime        @default(now())

  @@index([userId])
  @@index([studentId])
  @@index([status])
}

model PrefectBoard {
  id String @id @default(uuid())
  entranceDay                     DateTime?
  entranceNo                      String?
  firstTermPlace                  String?
  firstTermMarks                  Float?
  secondTermPlace                 String?
  secondTermMarks                 Float?
  thirdTermPlace                  String?
  thirdTermMarks                  Float?
  absentDaysCount                 Int?
  isPrefect                       Boolean         @default(false)
  isPrefectYears                  Int[]
  isClassLeader                   Boolean         @default(false)
  isClassLeaderYears              Int[]
  participateForCompetitions      Boolean         @default(false)
  participateForCompetitionsYears Int[]
  isInAnnouncingClub              Boolean         @default(false)
  isInAnnouncingClubYears         Int[]
  isOnStage                       Boolean         @default(false)
  isOnStageYears                  Int[]
  participateToKatina             Boolean         @default(false)
  participateToKatinaYears        Int[]
  poyaDayCount                    Int?
  studentAgreement                Boolean         @default(false)
  parentsAgreement                Boolean         @default(false)
  libraryStatus                   LibraryStatus?
  teachersAgreement               Boolean         @default(false)
  teachersAgreementFile           String?
  teachersConfirmFile             String?
  regNo                           String?
  marks                           Float?
  status                          SelectionStatus @default(PENDING)
  date                            DateTime?
  createdAt                       DateTime        @default(now())
  address                         String?
  fullName                        String
  grade                           String?
  libraryStatusConfirmationFile   String?
  parentsName                     String?
  specialNote                     String?
}

model RefreshToken {
  id String @id @default(uuid())
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdByIp  String?
  revokedByIp  String?
  replacedById String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Special {
  id String @id @default(uuid())
  dancing              Json?
  kathika              Json?
  padyagayana          Json?
  debate               Json?
  acting               Json?
  singing              Json?
  prefectOrClassLeader Json?
  committee            Json?
  other                Json?
  announcingFormId     String?         @unique
  createdAt            DateTime        @default(now())
  announcing           Json?
  announcingForm AnnouncingForm? @relation(fields: [announcingFormId], references: [id])
}

model StudentRequest {
  id String @id @default(uuid())
  fullNameWithSurname    String
  nameWithInitials       String?
  dob                    DateTime?
  address                String?
  phone1                 String?
  phone2                 String?
  school                 String?
  earlierSchool          Boolean                 @default(false)
  earlierSchoolReason    String?
  reasonForLeave         String?
  fatherFullName         String?
  fatherJob              String?
  fatherJobAddress       String?
  motherFullName         String?
  motherJob              String?
  motherJobAddress       String?
  guardianFullName       String?
  guardianJob            String?
  guardianJobAddress     String?
  emergencyPersonName    String?
  emergencyPersonAddress String?
  emergencyNumber        String?
  disabilities           Boolean                 @default(false)
  disabilityReason       String?
  medicated              Boolean                 @default(false)
  medicine               String?
  registrationPayment    Float?
  registrationDate       DateTime?
  indexNo                String?
  libraryNo              String?
  house                  String?
  grade                  String?
  studentActiveMonitor   StudentMonitor          @default(NOT_GIVEN)
  agreeToTerms           Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  status                 StudentRequestStatus    @default(PENDING)
  studentImage           String?
  userId                 String?
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  siblings StudentRequestSibling[]
  payments RegistrationPayment[]

  @@index([userId])
}

model RegistrationPayment {
  id String @id @default(uuid())
  amount Float
  studentRequestId String?
  studentRequest StudentRequest? @relation(fields: [studentRequestId], references: [id])
  studentId String?
  student Student? @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
}

model StudentRequestSibling {
  id String @id @default(uuid())
  studentRequestId String
  name             String
  grade            String?
  studentRequest StudentRequest @relation(fields: [studentRequestId], references: [id])

  @@index([studentRequestId])
}

model StudentSibling {
  id String @id @default(uuid())
  studentId String
  name      String
  grade     String?
  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model User {
  id String @id @default(uuid())
  email        String         @unique
  passwordHash String
  fullName     String?
  role         UserRole       @default(STUDENT)
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt DateTime @updatedAt
  refreshTokens RefreshToken[]
  students       Student[]
  studentRequests StudentRequest[]
  contactUs      ContactUs[]
}

enum StudentMonitor {
  GIVEN
  NOT_GIVEN
}

enum LibraryStatus {
  VERY_GOOD
  GOOD
  NORMAL
  WEAK
}

enum SelectionStatus {
  SELECTED
  NOT_SELECTED
  PENDING
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum StudentRequestStatus {
  ACCEPTED
  REJECTED
  PENDING
}

enum ContactUsStatus {
  READ
  NOT_READ
}

model Marks {
  id          String   @id @default(uuid())
  studentId   String
  year        Int
  teacherName String?
  term1Marks  Float?
  term2Marks  Float?
  term3Marks  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([year])
}
